{
  "name": "skill-manager",
  "version": "1.0.0",
  "description": "Manage AI coding tool skills across openclaw, Claude Code, and Codex",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "prepare": "husky"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "lib/**/*.js"
    ]
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "supertest": "^7.2.2"
  }
}
