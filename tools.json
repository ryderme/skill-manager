{
  "tools": {
    "openclaw": "~/.openclaw/skills",
    "claudecode": "~/.claude/skills",
    "codex": "~/.codex/skills"
  },
  "skillsDir": [
    "~/github",
    {
      "path": "~/.agents/skills",
      "group": ".agents"
    }
  ],
  "excludeProjects": [
    "everything-claude-code",
    "skill-manager"
  ],
  "rules": {
    "google-trends-seo-skill": {
      "exclude": [
        "openclaw",
        "claudecode",
        "codex"
      ]
    },
    "baijiahao-hot-tasks": {
      "exclude": [
        "codex"
      ]
    },
    "baijiahao-pipeline": {
      "exclude": [
        "codex"
      ]
    },
    "baijiahao-task-article-writer": {
      "exclude": [
        "codex"
      ]
    },
    "baoyu-cf-r2-upload": {
      "exclude": [
        "codex"
      ]
    },
    "agent-browser": {
      "exclude": [
        "openclaw",
        "claudecode",
        "codex"
      ]
    },
    "architecture-diagram-skill": {
      "exclude": [
        "openclaw",
        "claudecode",
        "codex"
      ]
    }
  },
  "groupRules": {
    "baijiahao": {
      "only": [
        "openclaw"
      ]
    },
    "opennews-mcp": {
      "exclude": [
        "claudecode"
      ]
    },
    "opentwitter-mcp": {
      "exclude": [
        "claudecode"
      ]
    },
    "gstack": {
      "exclude": [
        "openclaw"
      ]
    },
    "baoyu-skills": {
      "exclude": [
        "claudecode"
      ]
    }
  },
  "toolRules": {},
  "deletedSkills": [
    "find-skills",
    "architecture-diagram-skill",
    "diagram-exporter-skill",
    "google-trends-seo-skill",
    "topic-curation",
    "topic-discovery",
    "baoyu-cf-r2-upload"
  ]
}
